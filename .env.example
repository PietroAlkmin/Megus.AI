PORT=3000
LOG_LEVEL=info

# IA — provedor-agnóstico (atrás de IAIProvider). Modelo por env.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL_CHAT=gpt-5.4-mini
AI_MODEL_VISION=gpt-5.5

# Mensageria — Evolution API (Baileys)
MESSAGING_PROVIDER=evolution
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=megus

# Fiscal / CPF (mock no MVP)
FISCAL_PROVIDER=mock
CPF_PROVIDER=mock

# Regras
COMPROVANTE_MIN_CONFIDENCE=0.8
CPF_MAX_ATTEMPTS=2

# Persistência (Azure SQL). Vazio = repos in-memory (demo).
# Formato Node (mssql), traduzido da connection string ADO.NET do Azure:
# DATABASE_URL=Server=tcp:megusdata.database.windows.net,1433;Database=megusDB;User Id=pietro;Password=***;Encrypt=true
